generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String             @unique
  password         String
  phone            String?            @unique
  phoneVerified    Boolean            @default(false)
  targetRole       String?
  techStack        String[]
  experienceYears  Int?
  role             String             @default("admin")  // admin | recruiter | viewer
  orgId            String?
  // Subscription
  plan             String             @default("free")   // free | pro | enterprise
  stripeCustomerId String?            @unique
  stripeSubId      String?            @unique
  planExpiresAt    DateTime?
  interviewsThisMonth Int             @default(0)
  monthResetAt     DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  resumes          Resume[]
  interviewSessions InterviewSession[]
  campaigns        InterviewCampaign[]
  ownedOrg         Organization?
  teamMembership   TeamMember?
  questionBank     QuestionBank[]
  webhooks         WebhookConfig[]
  copilotLinkSessions CopilotLinkSession[]
  jobDescriptions  JobDescription[]
  jobApplications  JobApplication[]
  autoApplyJobs    AutoApplyJob[]
  autoApplySettings AutoApplySettings?
}

// ── Laptop ↔ phone (same account): share STT text for answer on phone ─
model CopilotLinkSession {
  id              String   @id @default(cuid())
  userId          String
  joinToken       String   @unique
  lastTranscript  String   @default("")
  lastSeq         Int      @default(0)
  lastQuestion    String?
  lastAnswer      String?  @db.Text
  expiresAt       DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  ownerId     String       @unique
  createdAt   DateTime     @default(now())
  owner       User         @relation(fields: [ownerId], references: [id])
  members     TeamMember[]
}

model TeamMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String       @unique
  role      String       @default("recruiter")  // recruiter | viewer
  invitedBy String
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id              String    @id @default(cuid())
  userId          String
  fileName        String
  fileType        String
  rawText         String
  parsedData      Json?
  analysisReport  Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]
  resumeMatches   ResumeMatch[]
}

model InterviewSession {
  id                  String     @id @default(cuid())
  userId              String
  resumeId            String?
  title               String
  role                String
  difficulty          String
  roundType           String
  status              String     @default("pending")
  totalQuestions      Int        @default(0)
  tabSwitchCount      Int        @default(0)
  audioKey            String?
  language            String     @default("en")
  persona             String     @default("friendly")
  transcript          String?
  integrityFlag       String     @default("clean")
  multipleFacesCount  Int        @default(0)
  noFaceCount         Int        @default(0)
  lookingAwayCount    Int        @default(0)
  noiseCount          Int        @default(0)
  copyPasteCount      Int        @default(0)
  adaptiveCheckpointDone Boolean @default(false)
  adaptiveAdjustment  String?
  adaptiveNote        String?
  panelInterview      Boolean    @default(false)
  pairProgramming     Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume              Resume?    @relation(fields: [resumeId], references: [id])
  questions           Question[]
  feedbackReport      FeedbackReport?

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Question {
  id          String           @id @default(cuid())
  sessionId   String
  text        String
  type        String
  orderIndex  Int
  panelAgent  String?          // technical | hr | domain (3-AI panel)
  starterCode String?          @db.Text
  codeLanguage String?
  createdAt   DateTime         @default(now())
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers     Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  text       String
  qualityScore     Int?
  confidenceScore  Int?
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ── Webhook Configuration ────────────────────────────────────────
model WebhookConfig {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             String   // slack | greenhouse | lever | workday | custom
  url              String   // webhook URL
  secret           String?  // optional signing secret
  events           String[] // interview_completed | shortlisted | score_threshold
  scoreThreshold   Int?     // auto-shortlist if score >= this
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model QuestionBank {
  id         String   @id @default(cuid())
  userId     String
  text       String
  category   String   // technical | hr | behavioral | system_design | dsa
  difficulty String   @default("intermediate")
  tags       String[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Password Reset ───────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Phone OTP ────────────────────────────────────────────────────
model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

model FeedbackReport {
  id                  String           @id @default(cuid())
  sessionId           String           @unique
  overallScore        Int
  technicalScore      Int
  communicationScore  Int
  confidenceScore     Int
  strengths           String[]
  weakAreas           String[]
  betterAnswers       Json
  improvementRoadmap  String[]
  summary             String
  createdAt           DateTime         @default(now())
  session             InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ── Bulk Interview Campaign ──────────────────────────────────────

model InterviewCampaign {
  id            String             @id @default(cuid())
  userId        String
  title         String
  role          String
  difficulty    String
  roundType     String
  questionCount Int                @default(5)
  description   String?
  status        String             @default("active")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invites       CandidateInvite[]
  slots         InterviewSlot[]
}

model CandidateInvite {
  id             String             @id @default(cuid())
  campaignId     String
  email          String
  name           String?
  token          String             @unique @default(cuid())
  status         String             @default("pending")
  emailSent      Boolean            @default(false)
  reminderSent   Boolean            @default(false)
  sessionId      String?            @unique
  photoUrl       String?
  scheduledAt    DateTime?
  slotId         String?
  portalPassword String?
  createdAt      DateTime           @default(now())
  campaign       InterviewCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  slot           InterviewSlot?     @relation(fields: [slotId], references: [id])
  notes          CandidateNote[]
}

// ── Recruiter Notes ──────────────────────────────────────────────
model CandidateNote {
  id        String          @id @default(cuid())
  inviteId  String
  userId    String
  text      String
  createdAt DateTime        @default(now())
  invite    CandidateInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId])
}

// ── Job Application Agent ────────────────────────────────────────
model JobApplication {
  id               String   @id @default(cuid())
  userId           String
  resumeId         String?
  jobTitle         String
  company          String?
  jobUrl           String?
  jobDescription   String   @db.Text
  // AI outputs
  coverLetter      String?  @db.Text
  interviewQuestions Json?  // GeneratedQuestion[]
  applicationChecklist Json? // ChecklistStep[]
  resumeGapAnalysis Json?   // GapAnalysis
  tailoredResumeBullets Json? // TailoredBullets[]
  followUpEmailDraft String? @db.Text
  // Status tracking
  status           String   @default("draft") // draft | applied | interview | offer | rejected
  notes            String?  @db.Text
  appliedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

// ── Job Description & Resume Matching ───────────────────────────
model JobDescription {
  id          String        @id @default(cuid())
  userId      String
  title       String
  company     String?
  description String        @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches     ResumeMatch[]

  @@index([userId])
}

model ResumeMatch {
  id               String         @id @default(cuid())
  jobDescriptionId String
  resumeId         String
  score            Int            // 0-100
  missingSkills    String[]
  matchedSkills    String[]
  summary          String         @db.Text
  recommendation   String         // strong_match | good_match | partial_match | weak_match
  createdAt        DateTime       @default(now())
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([jobDescriptionId, resumeId])
  @@index([jobDescriptionId])
}

// ── Auto Job Apply Agent ─────────────────────────────────────────
model AutoApplyJob {
  id               String   @id @default(cuid())
  userId           String
  resumeId         String?
  // Job details (from JSearch API or manual)
  jobTitle         String
  company          String
  location         String?
  jobUrl           String?
  jobDescription   String   @db.Text
  salary           String?
  jobType          String?  // full-time | part-time | contract
  source           String   @default("jsearch") // jsearch | manual
  externalId       String?  // JSearch job_id
  // AI outputs
  matchScore       Int?     // 0-100
  matchedSkills    String[]
  missingSkills    String[]
  coverLetter      String?  @db.Text
  hrEmail          String?
  // Status
  status           String   @default("found")
  // found | skipped | applied | email_sent | interview | offer | rejected
  appliedAt        DateTime?
  emailSentAt      DateTime?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

// ── Auto Apply Settings ──────────────────────────────────────────
model AutoApplySettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  resumeId         String?
  targetRole       String
  location         String   @default("India")
  minMatchScore    Int      @default(65)
  autoEmailEnabled Boolean  @default(false)
  companyName      String   @default("Candidate")
  dailyLimit       Int      @default(10)
  isActive         Boolean  @default(false)
  lastRunAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Interview Scheduling ─────────────────────────────────────────
model InterviewSlot {
  id          String             @id @default(cuid())
  campaignId  String
  startsAt    DateTime
  durationMin Int                @default(30)
  isBooked    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  campaign    InterviewCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invites     CandidateInvite[]
}
